TCB_ENV=gaya-cloudbase-6gq8izg8eeafd22b

# Tencent Cloud account keys for tcb CLI login
TENCENTCLOUD_SECRETID=your_tencent_secret_id
TENCENTCLOUD_SECRETKEY=your_tencent_secret_key

# App session token config
APP_JWT_SECRET=replace_with_random_long_string
ACCESS_TOKEN_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=30d

# Aliyun PNVS keys
ALIYUN_ACCESS_KEY_ID=your_aliyun_ak
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_sk
PNVS_SMS_SIGN_NAME=your_sms_sign
PNVS_SMS_TEMPLATE_CODE=your_sms_template_code

# HTTP domain for smoke tests
AUTH_API_BASE_URL=https://your-envid-yourappid.ap-shanghai.app.tcloudbase.com
