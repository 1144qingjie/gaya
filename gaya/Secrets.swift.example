import Foundation

/// 集中管理所有敏感信息。
/// 此文件已加入 .gitignore，不会被提交到版本控制。
/// 首次克隆项目时，请复制 Secrets.swift.example 为 Secrets.swift 并填入真实值。
enum Secrets {

    // MARK: - 阿里云号码认证 (ATAuthSDK / PNVS)
    /// 从阿里云号码认证控制台 → 方案管理获取的 SDK 密钥
    static let pnvsAuthSecret = "<YOUR_PNVS_AUTH_SECRET>"

    // MARK: - 火山引擎 (VolcEngine)
    /// 火山引擎控制台 → 应用管理
    static let volcAppId = "<YOUR_VOLC_APP_ID>"
    /// 火山引擎控制台 → 密钥管理 → Access Key
    static let volcAccessKey = "<YOUR_VOLC_ACCESS_KEY>"
    /// 火山引擎控制台 → 密钥管理 → Secret Key
    static let volcSecretKey = "<YOUR_VOLC_SECRET_KEY>"
    /// 火山引擎端到端语音大模型 App Key
    static let volcAppKey = "<YOUR_VOLC_APP_KEY>"
    /// 火山引擎融合信息搜索 API Key
    static let volcWebSearchApiKey = "<YOUR_VOLC_WEB_SEARCH_API_KEY>"

    // MARK: - 豆包 / Ark
    /// 豆包(Ark) 平台 API Key
    static let arkApiKey = "<YOUR_ARK_API_KEY>"

    // MARK: - CloudBase 后端
    /// 腾讯云 CloudBase HTTP 访问域名
    static let cloudBaseURL = "<YOUR_CLOUDBASE_HTTP_URL>"
}
